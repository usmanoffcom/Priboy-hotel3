# Пример для деплоя priboy1.ru — репозиторий https://github.com/usmanoffcom/Priboy-hotel3
# Скопируйте в .env.deploy и заполните:
#   cp .env.deploy.example .env.deploy
# Файл .env.deploy в .gitignore — не коммитить.

DEPLOY_USER="root"
DEPLOY_HOST="YOUR_SERVER_IP_OR_HOST"
DEPLOY_SSH_KEY="$HOME/.ssh/YOUR_PRIVATE_KEY"

# При необходимости переопределите в .env.deploy:
# DEPLOY_REMOTE_DIR="/var/www/priboy1.ru-nextjs"
# DEPLOY_DOMAIN="priboy1.ru"
# DEPLOY_PORT="3003"
